{
  "name": "@pt-viewer/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:css": "tailwindcss -i src/styles.css -o public/styles.css --minify",
    "dev": "npm run build:css && wrangler dev",
    "deploy": "npm run build:css && wrangler deploy",
    "db:local": "wrangler d1 execute DB --local --file ../../db/schema.sql && wrangler d1 execute DB --local --file tests/fixtures/seed.sql",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "hono": "^4.8.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250620.0",
    "@tailwindcss/cli": "^4.1.11",
    "tailwindcss": "^4.1.11",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4",
    "wrangler": "^4.22.0"
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "sharp@0.34.5": true,
    "workerd@1.20260701.1": true
  }
}
